# ── STEP 1: Copy this file ──────────────────────────────────────────────────
# cp .env.example .env        (Mac/Linux)
# copy .env.example .env      (Windows)
# Then fill in every value below.
# ─────────────────────────────────────────────────────────────────────────────

# MongoDB Atlas connection string
# atlas.mongodb.com → Connect → Drivers → copy the string, replace <password>
MONGO_URI=mongodb+srv://USERNAME:PASSWORD@cluster.mongodb.net/healthcare

# Any long random string (32+ characters) for signing JWT tokens
JWT_SECRET=replace-this-with-any-long-random-string-abcdef123456

# Any random string used to salt patient ID hashes before they go on-chain
PATIENT_ID_SALT=replace-this-with-another-random-string-xyz789

# Alchemy Sepolia RPC endpoint
# alchemy.com → New App → Ethereum + Sepolia → View Key → copy HTTPS URL
SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_ALCHEMY_KEY

# MetaMask private key (the wallet that pays gas + signs blockchain tx)
# MetaMask → click account → ⋮ → Account Details → Export Private Key
# Must start with 0x
PRIVATE_KEY=0xYOUR_METAMASK_PRIVATE_KEY

# Same wallet's public address (shown at top of MetaMask)
BACKEND_WALLET_ADDRESS=0xYOUR_METAMASK_WALLET_ADDRESS

# Fill this AFTER running: npm run deploy
CONTRACT_ADDRESS=

# Gmail address + App Password for sending OTP emails
# App Password: myaccount.google.com → Security → 2-Step Verification → App passwords
GMAIL_USER=youremail@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

PORT=3000
